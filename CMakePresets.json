{
    "version": 3,
    "configurePresets": [
        {
            "name": "linux-debug",
            "displayName": "Linux Debug",
            "description": "Linux build with Clang, Debug configuration",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "linux-release",
            "displayName": "Linux Release",
            "description": "Linux build with Clang, Release configuration",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "mingw-gcc-ucrt-debug",
            "displayName": "GCC 15.1.0 x86_64-w64-mingw32 (ucrt64) Debug",
            "description": "Using compilers: C = gcc.exe, CXX = g++.exe",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "CMAKE_C_COMPILER": "gcc.exe",
                "CMAKE_CXX_COMPILER": "g++.exe",
                "CMAKE_BUILD_TYPE": "Debug"
            },
            "environment": {
                "PATH": "$env{MSYS2_ROOT}/ucrt64/bin;$penv{PATH}"
            },
            "condition": {
                "type": "allOf",
                "conditions": [
                    {
                        "type": "equals",
                        "lhs": "${hostSystemName}",
                        "rhs": "Windows"
                    },
                    {
                        "type": "notEquals",
                        "lhs": "$env{MSYS2_ROOT}",
                        "rhs": ""
                    }
                ]
            }
        },
        {
            "name": "mingw-gcc-ucrt-release",
            "displayName": "GCC 15.1.0 x86_64-w64-mingw32 (ucrt64) Release",
            "description": "Using compilers: gcc.exe, CXX = g++.exe",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "CMAKE_C_COMPILER": "gcc.exe",
                "CMAKE_CXX_COMPILER": "g++.exe",
                "CMAKE_BUILD_TYPE": "Release"
            },
            "environment": {
                "PATH": "$env{MSYS2_ROOT}/ucrt64/bin;$penv{PATH}"
            },
            "condition": {
                "type": "allOf",
                "conditions": [
                    {
                        "type": "equals",
                        "lhs": "${hostSystemName}",
                        "rhs": "Windows"
                    },
                    {
                        "type": "notEquals",
                        "lhs": "$env{MSYS2_ROOT}",
                        "rhs": ""
                    }
                ]
            }
        }
    ],
    "buildPresets": [
        {
            "name": "linux-debug",
            "configurePreset": "linux-debug"
        },
        {
            "name": "linux-release",
            "configurePreset": "linux-release"
        },
        {
            "name": "mingw-gcc-ucrt-debug",
            "configurePreset": "mingw-gcc-ucrt-debug"
        },
        {
            "name": "mingw-gcc-ucrt-release",
            "configurePreset": "mingw-gcc-ucrt-release"
        }
    ]
}